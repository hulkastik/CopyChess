# Vorlage. Auf dem Server als .env anlegen — .env selbst ist nicht eingecheckt.

DATABASE_URL="file:./dev.db"

# ─── Ports ───────────────────────────────────────────────────────────────────
# Port des Spielservers. Steuert BEIDES: den Socket-Prozess und die
# Weiterleitung von /socket.io/ in next.config.ts.
# Wird beim BUILD ausgewertet — nach einer Aenderung neu bauen, nicht nur
# neu starten.
SOCKET_PORT=3001

# Adresse des Next-Prozesses aus Sicht des Spielservers. Darueber legt er
# Partien an. Laeuft Next auf einem anderen Port, MUSS das hier stehen, sonst
# schlaegt jedes Annehmen einer Herausforderung fehl.
NEXT_API_URL="http://localhost:3000"

# ─── Sicherheit ──────────────────────────────────────────────────────────────
# Trennt interne Aufrufe des Spielservers von Browser-Anfragen UND ist der
# Schluessel, mit dem Sitzungs-Token signiert werden.
# Auf einem erreichbaren Server zwingend durch einen eigenen Wert ersetzen:
#   openssl rand -base64 48
INTERNAL_API_SECRET="chess-internal-dev-secret"

# ─── Optional ────────────────────────────────────────────────────────────────
# Nur setzen, wenn der Spielserver bewusst unter einer eigenen Adresse laeuft.
# Normalfall: leer lassen. Der Browser nimmt dann dieselbe Herkunft wie die
# Seite, und Next reicht /socket.io/ weiter — kein CORS, keine Tunnel-Regel.
# Ein alter Wert wie http://localhost:3001 landet fest im Browser-Bundle und
# schickt jeden Besucher gegen seinen eigenen Rechner.
# NEXT_PUBLIC_SOCKET_URL=

# Erlaubte Herkuenfte des Spielservers. Leer = anfragende Herkunft wird
# gespiegelt. Bei gleicher Herkunft ohnehin ohne Wirkung.
# CLIENT_ORIGIN="https://chess.example.com"

# Weiterleitungsziel abweichend vom aus SOCKET_PORT abgeleiteten localhost.
# SOCKET_INTERNAL_URL="http://localhost:3001"
