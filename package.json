{
  "name": "chess-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate && node ./scripts/copy-stockfish.js",
    "copy-stockfish": "node ./scripts/copy-stockfish.js",
    "lint": "next lint",
    "seed": "node ./scripts/seed.js",
    "server": "npm --prefix server run dev",
    "test:rules": "npm --prefix server run test:rules",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "test:accuracy": "npm --prefix server run test:accuracy",
    "test": "npm run test:rules && npm run test:accuracy && npm run test:rating",
    "icons": "node ./scripts/generate-icons.js",
    "test:rating": "npm --prefix server run test:rating"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "chess.js": "^1.4.0",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.4",
    "socket.io-client": "^4.8.3",
    "stockfish": "^18.0.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0"
  }
}
